{
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/(.*\\.(png|jpg|jpeg|webp|svg|gif|ico|avif))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=864000, stale-while-revalidate=172800"
        }
      ]
    }
  ]
}
